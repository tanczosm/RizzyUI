{
  "name": "@jalexsocial/rizzyui",
  "version": "0.6.2",
  "description": "Client library for Asp.net RizzyUI",
  "main": "dist/js/rizzyui.js",
  "module": "dist/js/rizzyui.es.js",
  "exports": {
    ".": {
      "import": "./dist/js/rizzyui.es.js",
      "require": "./dist/js/rizzyui.js"
    },
    "./csp": {
      "import": "./dist/js/rizzyui-csp.es.js",
      "require": "./dist/js/rizzyui-csp.js"
    },
    "./antiforgerySnippet": {
      "import": "./dist/js/antiforgerySnippet.es.js",
      "require": "./dist/js/antiforgerySnippet.min.js"
    },
    "./antiforgerySnippet.js": "./dist/js/antiforgerySnippet.js",
    "./antiforgerySnippet.min.js": "./dist/js/antiforgerySnippet.min.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./build/build-all.mjs",
    "build:clean": "node ./build/clean-generated.mjs",
    "build:js": "node ./build/build-js.mjs",
    "build:assets": "node ./build/build-assets.mjs",
    "build:antiforgery": "node ./build/build-antiforgery.mjs",
    "build:css": "node ./build/build-css.mjs",
    "build:safelist": "node ./build/parse-tailwind-css.js",
    "build:copy": "node ./build/copy-dist.mjs",
    "dev": "vite",
    "preview": "vite preview --outDir dist",
    "analyze": "vite build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalexsocial/RizzyUI.git"
  },
  "keywords": [
    "asp.net",
    "blazor",
    "tailwind",
    "ssr",
    "htmx",
    "rizzy"
  ],
  "author": "Michael Tanczos",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jalexsocial/RizzyUI/issues"
  },
  "homepage": "https://github.com/jalexsocial/RizzyUI#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "postcss": "^8.5.3",
    "postcss-selector-parser": "^7.1.0",
    "repomix": "^0.3.6",
    "rollup-plugin-visualizer": "^5.14.0",
    "tw-animate-css": "^1.3.4",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.8",
    "@alpinejs/csp": "^3.15.8",
    "@alpinejs/focus": "^3.15.8",
    "@alpinejs/intersect": "^3.15.8",
    "@floating-ui/dom": "^1.7.0",
    "@tailwindcss/forms": "^0.5.10",
    "alpinejs": "^3.15.8",
    "aspnet-client-validation": "^0.11.1",
    "canvas-confetti": "^1.9.3",
    "async-alpine": "^2.0.3",
    "htmx.org": "^2.0.4",
    "shadcn-prose": "^1.0.8",
    "simple-notify": "^1.0.6",
    "tailwindcss": "^4.2.1",
    "tailwindcss-inset": "^1.0.0"
  }
}
