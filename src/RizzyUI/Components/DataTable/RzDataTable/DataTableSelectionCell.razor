@namespace RizzyUI
@inherits RzComponent<DataTableSelectionCell.Slots>

<HtmlElement Element="@EffectiveElement"
             id="@Id"
             @attributes="@AdditionalAttributes"
             class="@SlotClasses.GetBase()"
             data-slot="data-table-selection-cell">
    <div class="@SlotClasses.GetContent()" data-slot="@DataTableSelectionCell.SlotNames.NameOf(SlotTypes.Content)">
        <DataTableRowSelectCheckbox RowExpr="@RowExpr" AriaLabel="@AriaLabel" />
    </div>
</HtmlElement>
