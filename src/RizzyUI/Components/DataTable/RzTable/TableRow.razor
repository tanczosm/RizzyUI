@namespace RizzyUI
@inherits RzComponent<TableRowSlots>

<CascadingValue Value="this" Name="ParentTableRow" IsFixed="true">
    <tr id="@Id"
        @attributes="@AdditionalAttributes"
        class="@SlotClasses.GetBase()"
        data-slot="table-row"
        data-state="@(IsSelected ? "selected" : null)">
        @ChildContent
    </tr>
</CascadingValue>
