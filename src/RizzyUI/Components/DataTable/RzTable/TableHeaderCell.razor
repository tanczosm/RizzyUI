@namespace RizzyUI
@using Blazicons

@typeparam TItem
@inherits RzComponent<TableHeaderCellSlots>

<HtmlElement Element="@EffectiveElement" id="@Id" @attributes="@AdditionalAttributes" class="@SlotClasses.GetBase()" data-slot="table-head" aria-sort="@_ariaSortValue">
    @if (Sortable)
    {
        <button type="button"
                id="@($"{Id}-sort")"
                class="@SlotClasses.GetSortableButton()"
                data-slot="@TableHeaderCellSlotNames.NameOf(TableHeaderCellSlotTypes.SortableButton)"
                data-column-key="@EffectiveColumnKey"
                data-sort-direction="@ToRequestSortDirection(_nextSortDirection)"
                data-previous-sort-direction="@ToRequestSortDirection(_currentSortDirection)"
                data-request="@RequestPayload"
                aria-label="@_sortButtonAriaLabel"
                onclick="@SortDispatchScript">
            <span class="@SlotClasses.GetTitleSpan()" data-slot="@TableHeaderCellSlotNames.NameOf(TableHeaderCellSlotTypes.TitleSpan)">@ChildContent</span>
            @if (SortIndicatorIcon != null)
            {
                <div class="@SlotClasses.GetSortIndicator()" data-slot="@TableHeaderCellSlotNames.NameOf(TableHeaderCellSlotTypes.SortIndicator)">
                    <Blazicon Svg="SortIndicatorIcon" aria-hidden="true" />
                </div>
            }
        </button>
    }
    else
    {
        <span class="@SlotClasses.GetTitleSpan()" data-slot="@TableHeaderCellSlotNames.NameOf(TableHeaderCellSlotTypes.TitleSpan)">@ChildContent</span>
    }
</HtmlElement>
