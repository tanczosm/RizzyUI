                                <th scope="col" class="w-2/5 px-4 py-3">Description</th>
                                <th scope="col" class="w-1/5 px-4 py-3">Type</th>
                                <th scope="col" class="px-4 py-3">Default</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
                            <tr class="align-top"><td class="px-4 py-4"><code class="font-mono font-medium text-sky-600 dark:text-sky-400">Orientation</code></td><td class="px-4 py-4 text-zinc-600 dark:text-zinc-400">Selects horizontal or vertical motion.</td><td class="px-4 py-4"><code class="font-mono text-violet-600 dark:text-violet-400">MarqueeOrientation</code></td><td class="px-4 py-4 text-zinc-500"><code class="font-mono">MarqueeOrientation.Horizontal</code></td></tr>
