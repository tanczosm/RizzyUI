@page "/components/blur-fade"
@using RizzyUI

<PageTitle>Blur Fade</PageTitle>

<RzQuickReferenceContainer>
    <RzArticle ProseWidth="ProseWidth.UltraWide">
        <SideContent>
            <RzQuickReference />
        </SideContent>
        <MainContent>
            <RzBreadcrumb class="mb-4 not-prose">
                <BreadcrumbList>
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Docs</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/components" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Components</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BreadcrumbPage>Blur Fade</BreadcrumbPage>
                    </BreadcrumbItem>
                </BreadcrumbList>
            </RzBreadcrumb>

            <RzHeading Level="HeadingLevel.H1" class="scroll-mt-20">Blur Fade</RzHeading>
            <RzParagraph>
                RzBlurFade is a single wrapper component for reveal effects on arbitrary child markup. The content remains fully server-rendered and semantic, while Alpine progressively enhances reveal timing for on-load and first-in-view behavior.
            </RzParagraph>

            <RzAlert Variant="ThemeVariant.Information" class="my-6 not-prose">
                <AlertTitle>Under the Hood</AlertTitle>
                <AlertDescription>
                    <p>The runtime behavior is powered by <code>x-data="rzBlurFade"</code> and optional <code>IntersectionObserver</code> usage when <code>InView</code> is enabled.</p>
                    <p>SSR markup is intentionally visible before JavaScript initializes, and reduced-motion users receive immediate visible content.</p>
                </AlertDescription>
            </RzAlert>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Basic Usage" class="scroll-mt-20">Basic Usage</RzHeading>
                <RzParagraph TextColor="SemanticColor.Foreground">
                    Use RzBlurFade as a thin wrapper for headings, paragraphs, cards, or any other child content. Staggering is achieved by varying Delay across sibling instances.
                </RzParagraph>

                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="space-y-4 p-8">
                        <RzBlurFade Delay="0.15">
                            <h3 class="text-2xl font-semibold">Hello from RizzyUI</h3>
                        </RzBlurFade>
                        <RzBlurFade Delay="0.3">
                            <p class="text-muted-foreground">This paragraph reveals shortly after the heading using the same wrapper component.</p>
                        </RzBlurFade>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;div class=&quot;space-y-4 p-8&quot;&gt;
    &lt;RzBlurFade Delay=&quot;0.15&quot;&gt;
        &lt;h3 class=&quot;text-2xl font-semibold&quot;&gt;Hello from RizzyUI&lt;/h3&gt;
    &lt;/RzBlurFade&gt;
    &lt;RzBlurFade Delay=&quot;0.3&quot;&gt;
        &lt;p class=&quot;text-muted-foreground&quot;&gt;This paragraph reveals shortly after the heading using the same wrapper component.&lt;/p&gt;
    &lt;/RzBlurFade&gt;
&lt;/div&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Scroll Into View" class="scroll-mt-20">Scroll Into View</RzHeading>
                <RzParagraph TextColor="SemanticColor.Foreground">
                    Enable InView for one-time reveal when each item first intersects the viewport.
                </RzParagraph>

                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="space-y-3 p-8">
                        @for (var i = 1; i <= 4; i++)
                        {
                            <RzBlurFade InView="true" Delay="@(0.1 * i)">
                                <div class="rounded-md border bg-card p-4">
                                    <p class="font-medium">Result @i</p>
                                    <p class="text-sm text-muted-foreground">Reveals once when scrolled into view.</p>
                                </div>
                            </RzBlurFade>
                        }
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;div class=&quot;space-y-3 p-8&quot;&gt;
    @@for (var i = 1; i &lt;= 4; i++)
    {
        &lt;RzBlurFade InView=&quot;true&quot; Delay=&quot;@@(0.1 * i)&quot;&gt;
            &lt;div class=&quot;rounded-md border bg-card p-4&quot;&gt;
                &lt;p class=&quot;font-medium&quot;&gt;Result @@i&lt;/p&gt;
                &lt;p class=&quot;text-sm text-muted-foreground&quot;&gt;Reveals once when scrolled into view.&lt;/p&gt;
            &lt;/div&gt;
        &lt;/RzBlurFade&gt;
    }
&lt;/div&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Direction and Blur Customization" class="scroll-mt-20">Direction and Blur Customization</RzHeading>
                <RzParagraph TextColor="SemanticColor.Foreground">
                    Choose direction, offset, and blur per instance to tune reveal motion.
                </RzParagraph>

                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="grid gap-3 p-8 sm:grid-cols-2">
                        <RzBlurFade Direction="BlurFadeDirection.Up" Offset="14" Blur="8px"><div class="rounded-md border p-3">Up</div></RzBlurFade>
                        <RzBlurFade Direction="BlurFadeDirection.Down" Offset="14" Blur="8px"><div class="rounded-md border p-3">Down</div></RzBlurFade>
                        <RzBlurFade Direction="BlurFadeDirection.Left" Offset="14" Blur="8px"><div class="rounded-md border p-3">Left</div></RzBlurFade>
                        <RzBlurFade Direction="BlurFadeDirection.Right" Offset="14" Blur="8px"><div class="rounded-md border p-3">Right</div></RzBlurFade>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;div class=&quot;grid gap-3 p-8 sm:grid-cols-2&quot;&gt;
    &lt;RzBlurFade Direction=&quot;BlurFadeDirection.Up&quot; Offset=&quot;14&quot; Blur=&quot;8px&quot;&gt;&lt;div class=&quot;rounded-md border p-3&quot;&gt;Up&lt;/div&gt;&lt;/RzBlurFade&gt;
    &lt;RzBlurFade Direction=&quot;BlurFadeDirection.Down&quot; Offset=&quot;14&quot; Blur=&quot;8px&quot;&gt;&lt;div class=&quot;rounded-md border p-3&quot;&gt;Down&lt;/div&gt;&lt;/RzBlurFade&gt;
    &lt;RzBlurFade Direction=&quot;BlurFadeDirection.Left&quot; Offset=&quot;14&quot; Blur=&quot;8px&quot;&gt;&lt;div class=&quot;rounded-md border p-3&quot;&gt;Left&lt;/div&gt;&lt;/RzBlurFade&gt;
    &lt;RzBlurFade Direction=&quot;BlurFadeDirection.Right&quot; Offset=&quot;14&quot; Blur=&quot;8px&quot;&gt;&lt;div class=&quot;rounded-md border p-3&quot;&gt;Right&lt;/div&gt;&lt;/RzBlurFade&gt;
&lt;/div&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="HTMX / Partial Rendering Integration" class="scroll-mt-20">HTMX / Partial Rendering Integration</RzHeading>
                <RzParagraph TextColor="SemanticColor.Foreground">
                    RzBlurFade is safe in server-rendered partials and HTMX swaps because the wrapper remains semantically neutral and SSR-first.
                </RzParagraph>
                <RzAlert Variant="ThemeVariant.Warning" class="mb-4 not-prose">
                    <AlertDescription>
                        The docs sample is static and does not call a live endpoint, but the markup below is copy-paste-ready for real HTMX regions.
                    </AlertDescription>
                </RzAlert>

                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="space-y-3 p-8" id="search-results">
                        <RzBlurFade InView="true"><div class="rounded-md border bg-card p-4">Result card A</div></RzBlurFade>
                        <RzBlurFade InView="true" Delay="0.06"><div class="rounded-md border bg-card p-4">Result card B</div></RzBlurFade>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-4">
&lt;div hx-get=&quot;/search/results&quot;
     hx-target=&quot;#search-results&quot;
     hx-swap=&quot;innerHTML&quot;&gt;
    Refresh Results
&lt;/div&gt;
                </RzCodeViewer>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;div id=&quot;search-results&quot; class=&quot;space-y-3&quot;&gt;
    &lt;RzBlurFade InView=&quot;true&quot;&gt;
        &lt;div class=&quot;rounded-md border bg-card p-4&quot;&gt;Result card A&lt;/div&gt;
    &lt;/RzBlurFade&gt;
    &lt;RzBlurFade InView=&quot;true&quot; Delay=&quot;0.06&quot;&gt;
        &lt;div class=&quot;rounded-md border bg-card p-4&quot;&gt;Result card B&lt;/div&gt;
    &lt;/RzBlurFade&gt;
&lt;/div&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Reduced Motion and Fallback Behavior" class="scroll-mt-20">Reduced Motion and Fallback Behavior</RzHeading>
                <RzParagraph TextColor="SemanticColor.Foreground">
                    Without JavaScript, content remains visible. For reduced-motion preferences, Alpine immediately applies final visible styles.
                </RzParagraph>

                <RzBrowser Layout="typeof(PreviewLayout)">
                    <RzBlurFade InView="true">
                        <div class="m-8 rounded-md border bg-card p-4 text-sm text-muted-foreground">
                            This wrapper never server-renders hidden state, so content is resilient to JS failures and still readable.
                        </div>
                    </RzBlurFade>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzBlurFade InView=&quot;true&quot;&gt;
    &lt;div class=&quot;rounded-md border bg-card p-4 text-sm text-muted-foreground&quot;&gt;
        This wrapper never server-renders hidden state, so content is resilient to JS failures and still readable.
    &lt;/div&gt;
&lt;/RzBlurFade&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Parameters" class="scroll-mt-20">Parameters</RzHeading>
                <table class="w-full text-sm not-prose">
                    <thead><tr class="border-b"><th class="p-2 text-left">Name</th><th class="p-2 text-left">Type</th><th class="p-2 text-left">Default</th></tr></thead>
                    <tbody>
                        <tr class="border-b"><td class="p-2">Direction</td><td class="p-2">BlurFadeDirection</td><td class="p-2">Down</td></tr>
                        <tr class="border-b"><td class="p-2">Offset</td><td class="p-2">double</td><td class="p-2">6</td></tr>
                        <tr class="border-b"><td class="p-2">Duration</td><td class="p-2">double</td><td class="p-2">0.4</td></tr>
                        <tr class="border-b"><td class="p-2">Delay</td><td class="p-2">double</td><td class="p-2">0</td></tr>
                        <tr class="border-b"><td class="p-2">Blur</td><td class="p-2">string</td><td class="p-2">6px</td></tr>
                        <tr class="border-b"><td class="p-2">InView</td><td class="p-2">bool</td><td class="p-2">false</td></tr>
                        <tr class="border-b"><td class="p-2">InViewMargin</td><td class="p-2">string</td><td class="p-2">-50px</td></tr>
                        <tr class="border-b"><td class="p-2">ChildContent</td><td class="p-2">RenderFragment?</td><td class="p-2">null</td></tr>
                        <tr class="border-b"><td class="p-2">Id</td><td class="p-2">string</td><td class="p-2">auto-generated</td></tr>
                        <tr><td class="p-2">Element</td><td class="p-2">string</td><td class="p-2">div</td></tr>
                    </tbody>
                </table>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Alpine API" class="scroll-mt-20">Alpine API</RzHeading>
                <table class="w-full text-sm not-prose">
                    <thead><tr class="border-b"><th class="p-2 text-left">Attribute</th><th class="p-2 text-left">Description</th></tr></thead>
                    <tbody>
                        <tr class="border-b"><td class="p-2">x-data=&quot;rzBlurFade&quot;</td><td class="p-2">Initializes the component runtime.</td></tr>
                        <tr class="border-b"><td class="p-2">data-direction</td><td class="p-2">up/down/left/right direction.</td></tr>
                        <tr class="border-b"><td class="p-2">data-offset</td><td class="p-2">Initial offset in pixels.</td></tr>
                        <tr class="border-b"><td class="p-2">data-duration</td><td class="p-2">Transition duration in seconds.</td></tr>
                        <tr class="border-b"><td class="p-2">data-delay</td><td class="p-2">Transition delay in seconds.</td></tr>
                        <tr class="border-b"><td class="p-2">data-blur</td><td class="p-2">Initial blur value.</td></tr>
                        <tr class="border-b"><td class="p-2">data-in-view</td><td class="p-2">Enables first-in-view reveal behavior.</td></tr>
                        <tr class="border-b"><td class="p-2">data-in-view-margin</td><td class="p-2">IntersectionObserver rootMargin.</td></tr>
                        <tr class="border-b"><td class="p-2">data-alpine-root</td><td class="p-2">Matches root Id for Alpine scope resolution.</td></tr>
                        <tr><td class="p-2">data-assets</td><td class="p-2">Present for consistency and empty by default ([]).</td></tr>
                    </tbody>
                </table>
                <RzParagraph TextColor="SemanticColor.Foreground" class="mt-4">
                    RzBlurFade emits no custom browser events and no Blazor callbacks. It is safe in HTMX swaps and InView mode reveals once per rendered instance.
                </RzParagraph>
            </section>
        </MainContent>
    </RzArticle>
</RzQuickReferenceContainer>
