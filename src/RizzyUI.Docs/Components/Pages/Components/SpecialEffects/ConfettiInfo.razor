@page "/components/confetti"
@using RizzyUI

<PageTitle>Confetti</PageTitle>

<RzQuickReferenceContainer>
    <RzArticle ProseWidth="ProseWidth.UltraWide">
        <SideContent>
            <RzQuickReference />
        </SideContent>
        <MainContent>
            <RzBreadcrumb class="mb-4 not-prose">
                <BreadcrumbList>
                    <BreadcrumbItem><BreadcrumbLink Href="/" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Docs</BreadcrumbLink></BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem><BreadcrumbLink Href="/components" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Components</BreadcrumbLink></BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem><BreadcrumbPage>Confetti</BreadcrumbPage></BreadcrumbItem>
                </BreadcrumbList>
            </RzBreadcrumb>

            <RzHeading Level="HeadingLevel.H1" QuickReferenceTitle="Confetti" class="scroll-mt-20">Confetti</RzHeading>
            <RzParagraph>
                <code>RzConfetti</code> provides a canvas-backed celebration host and <code>ConfettiTrigger</code> supplies typed trigger wiring. This implementation is SSR-first and uses Alpine for client behavior.
            </RzParagraph>

            <RzAlert Variant="ThemeVariant.Information" class="not-prose my-6">
                <AlertTitle>Under the Hood</AlertTitle>
                <AlertDescription>
                    Hosts are registered by <code>data-confetti-host</code>, and delegated listeners route trigger events by nearest host or <code>TargetId</code>.
                </AlertDescription>
            </RzAlert>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Confetti Demo" class="scroll-mt-20">Confetti Demo</RzHeading>
                <RzParagraph>Equivalent to MagicUI <code>confetti-demo.tsx</code>: decorative text with a hover trigger.</RzParagraph>
                <div class="not-prose relative my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" class="min-h-[22rem] rounded-md border bg-background p-8">
                        <div class="pointer-events-none bg-linear-to-b from-black to-gray-300/80 bg-clip-text text-center text-7xl font-semibold text-transparent dark:from-white dark:to-slate-900/10">Confetti</div>
                        <div class="mt-8 flex justify-center">
                            <ConfettiTrigger Trigger="ConfettiTriggerEvent.MouseEnter" Pattern="ConfettiPattern.Burst">
                                Hover for Confetti
                            </ConfettiTrigger>
                        </div>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzConfetti ManualStart=&quot;true&quot;&gt;
    &lt;ConfettiTrigger Trigger=&quot;ConfettiTriggerEvent.MouseEnter&quot;&gt;
        Hover for Confetti
    &lt;/ConfettiTrigger&gt;
&lt;/RzConfetti&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Basic Cannon" class="scroll-mt-20">Basic Cannon</RzHeading>
                <RzParagraph>Equivalent to <code>confetti-basic-cannon.tsx</code>.</RzParagraph>
                <div class="not-prose my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" class="min-h-40 rounded-md border bg-background p-6">
                        <ConfettiTrigger AsChild="true"><RzButton>Confetti 🎉</RzButton></ConfettiTrigger>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzConfetti ManualStart=&quot;true&quot;&gt;
    &lt;ConfettiTrigger AsChild=&quot;true&quot;&gt;&lt;RzButton&gt;Confetti 🎉&lt;/RzButton&gt;&lt;/ConfettiTrigger&gt;
&lt;/RzConfetti&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Random Direction" class="scroll-mt-20">Random Direction</RzHeading>
                <RzParagraph>Equivalent to <code>confetti-random-direction.tsx</code>.</RzParagraph>
                <div class="not-prose my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" class="min-h-40 rounded-md border bg-background p-6">
                        <ConfettiTrigger Pattern="ConfettiPattern.RandomDirection" AsChild="true"><RzButton>Random Confetti 🎉</RzButton></ConfettiTrigger>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;ConfettiTrigger Pattern=&quot;ConfettiPattern.RandomDirection&quot; AsChild=&quot;true&quot;&gt;
    &lt;RzButton&gt;Random Confetti 🎉&lt;/RzButton&gt;
&lt;/ConfettiTrigger&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Fireworks" class="scroll-mt-20">Fireworks</RzHeading>
                <RzParagraph>Equivalent to <code>confetti-fireworks.tsx</code>.</RzParagraph>
                <div class="not-prose my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" class="min-h-40 rounded-md border bg-background p-6">
                        <ConfettiTrigger Pattern="ConfettiPattern.Fireworks" AsChild="true"><RzButton>Trigger Fireworks</RzButton></ConfettiTrigger>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;ConfettiTrigger Pattern=&quot;ConfettiPattern.Fireworks&quot; AsChild=&quot;true&quot;&gt;
    &lt;RzButton&gt;Trigger Fireworks&lt;/RzButton&gt;
&lt;/ConfettiTrigger&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Stars" class="scroll-mt-20">Stars</RzHeading>
                <RzParagraph>Equivalent to <code>confetti-stars.tsx</code>.</RzParagraph>
                <div class="not-prose my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" Pattern="ConfettiPattern.Stars" class="min-h-40 rounded-md border bg-background p-6">
                        <ConfettiTrigger Pattern="ConfettiPattern.Stars" AsChild="true"><RzButton>Trigger Stars</RzButton></ConfettiTrigger>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;ConfettiTrigger Pattern=&quot;ConfettiPattern.Stars&quot; AsChild=&quot;true&quot;&gt;
    &lt;RzButton&gt;Trigger Stars&lt;/RzButton&gt;
&lt;/ConfettiTrigger&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Side Cannons" class="scroll-mt-20">Side Cannons</RzHeading>
                <RzParagraph>Equivalent to <code>confetti-side-cannons.tsx</code>.</RzParagraph>
                <div class="not-prose my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" class="min-h-40 rounded-md border bg-background p-6">
                        <ConfettiTrigger Pattern="ConfettiPattern.SideCannons" AsChild="true"><RzButton>Trigger Side Cannons</RzButton></ConfettiTrigger>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;ConfettiTrigger Pattern=&quot;ConfettiPattern.SideCannons&quot; AsChild=&quot;true&quot;&gt;
    &lt;RzButton&gt;Trigger Side Cannons&lt;/RzButton&gt;
&lt;/ConfettiTrigger&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Custom Shapes" class="scroll-mt-20">Custom Shapes</RzHeading>
                <RzParagraph>Equivalent to <code>confetti-custom-shapes.tsx</code> using the built-in <code>CustomShapes</code> pattern.</RzParagraph>
                <div class="not-prose my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" class="min-h-40 rounded-md border bg-background p-6">
                        <ConfettiTrigger Pattern="ConfettiPattern.CustomShapes" AsChild="true"><RzButton>Trigger Shapes</RzButton></ConfettiTrigger>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;ConfettiTrigger Pattern=&quot;ConfettiPattern.CustomShapes&quot; AsChild=&quot;true&quot;&gt;
    &lt;RzButton&gt;Trigger Shapes&lt;/RzButton&gt;
&lt;/ConfettiTrigger&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Emoji" class="scroll-mt-20">Emoji</RzHeading>
                <RzParagraph>Equivalent to <code>confetti-emoji.tsx</code> using the built-in <code>Emoji</code> pattern.</RzParagraph>
                <div class="not-prose my-6 rounded-lg border bg-card p-8">
                    <RzConfetti ManualStart="true" class="min-h-40 rounded-md border bg-background p-6">
                        <ConfettiTrigger Pattern="ConfettiPattern.Emoji" AsChild="true"><RzButton>Trigger Emoji</RzButton></ConfettiTrigger>
                    </RzConfetti>
                </div>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;ConfettiTrigger Pattern=&quot;ConfettiPattern.Emoji&quot; AsChild=&quot;true&quot;&gt;
    &lt;RzButton&gt;Trigger Emoji&lt;/RzButton&gt;
&lt;/ConfettiTrigger&gt;
                </RzCodeViewer>
            </section>
        </MainContent>
    </RzArticle>
</RzQuickReferenceContainer>
