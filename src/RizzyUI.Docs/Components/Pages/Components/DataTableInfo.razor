    private static string EncodeCode(string code) => HtmlEncoder.Default.Encode(code);

    private const string _basicUsageCode =
"""
<RzDataTable Items="_users" Config="_config" RowIdSelector="x => x.Id">
    <RzTable Border>
        <TableHeader>
            <template x-for="headerGroup in headerGroupViews" :key="headerGroup.id">
                <TableRow>
                    <template x-for="header in headerGroup.headers" :key="header.id">
