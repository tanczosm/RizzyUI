@page "/components/rainbow-button"
@using Blazicons
@using RizzyUI

<PageTitle>Rainbow Button</PageTitle>

<RzQuickReferenceContainer>
    <RzArticle ProseWidth="ProseWidth.UltraWide">
        <SideContent>
            <RzQuickReference />
        </SideContent>
        <MainContent>
            <RzBreadcrumb class="mb-4 not-prose">
                <BreadcrumbList>
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Docs</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/components" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Components</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BreadcrumbPage>Rainbow Button</BreadcrumbPage>
                    </BreadcrumbItem>
                </BreadcrumbList>
            </RzBreadcrumb>

            <RzHeading Level="HeadingLevel.H1" QuickReferenceTitle="Rainbow Button" class="scroll-mt-20">Rainbow Button</RzHeading>
            <RzParagraph>
                <code>RzRainbowButton</code> is a CTA-style button with animated rainbow border/glow styling. It renders as a native button by default, supports <code>AsChild</code> composition for links, and is SSR-safe with no Alpine dependency.
            </RzParagraph>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Basic Usage" class="scroll-mt-20">Basic Usage</RzHeading>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto p-8 flex justify-center">
                        <RzRainbowButton>Get Unlimited Access</RzRainbowButton>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzRainbowButton&gt;Get Unlimited Access&lt;/RzRainbowButton&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Outline Variant" class="scroll-mt-20">Outline Variant</RzHeading>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto p-8 flex justify-center">
                        <RzRainbowButton Variant="RainbowButtonVariant.Outline">Get Unlimited Access</RzRainbowButton>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzRainbowButton Variant="RainbowButtonVariant.Outline"&gt;
    Get Unlimited Access
&lt;/RzRainbowButton&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Size Variants" class="scroll-mt-20">Size Variants</RzHeading>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto p-8 flex flex-wrap items-center justify-center gap-3">
                        <RzRainbowButton Size="RainbowButtonSize.Default">Default</RzRainbowButton>
                        <RzRainbowButton Size="RainbowButtonSize.Small">Small</RzRainbowButton>
                        <RzRainbowButton Size="RainbowButtonSize.Large">Large</RzRainbowButton>
                        <RzRainbowButton Size="RainbowButtonSize.Icon" AriaLabel="Open settings">
                            <Blazicon Svg="@Lucide.Settings" aria-hidden="true" />
                        </RzRainbowButton>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzRainbowButton Size="RainbowButtonSize.Default"&gt;Default&lt;/RzRainbowButton&gt;
&lt;RzRainbowButton Size="RainbowButtonSize.Small"&gt;Small&lt;/RzRainbowButton&gt;
&lt;RzRainbowButton Size="RainbowButtonSize.Large"&gt;Large&lt;/RzRainbowButton&gt;
&lt;RzRainbowButton Size="RainbowButtonSize.Icon" AriaLabel="Open settings"&gt;
    &lt;Blazicon Svg="@Lucide.Settings" aria-hidden="true" /&gt;
&lt;/RzRainbowButton&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Link Composition with AsChild" class="scroll-mt-20">Link Composition with AsChild</RzHeading>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto p-8 flex justify-center">
                        <RzRainbowButton AsChild>
                            <a href="/components/buttons">Explore Buttons</a>
                        </RzRainbowButton>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzRainbowButton AsChild&gt;
    &lt;a href="/components/buttons"&gt;Explore Buttons&lt;/a&gt;
&lt;/RzRainbowButton&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Form Integration" class="scroll-mt-20">Form Integration Example</RzHeading>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto p-8 flex justify-center">
                        <div class="flex items-center gap-3">
                            <RzRainbowButton Type="submit">Submit</RzRainbowButton>
                            <RzRainbowButton Variant="RainbowButtonVariant.Outline" Type="reset">Reset</RzRainbowButton>
                        </div>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzRainbowButton Type="submit"&gt;Submit&lt;/RzRainbowButton&gt;
&lt;RzRainbowButton Variant="RainbowButtonVariant.Outline" Type="reset"&gt;
    Reset
&lt;/RzRainbowButton&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Accessibility" class="scroll-mt-20">Accessibility / Edge Case Example</RzHeading>
                <RzParagraph>
                    For icon-only usage, always provide <code>AriaLabel</code> so the action has a reliable accessible name.
                </RzParagraph>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto p-8 flex justify-center">
                        <RzRainbowButton Size="RainbowButtonSize.Icon" AriaLabel="Share">
                            <Blazicon Svg="@Lucide.Share2" aria-hidden="true" />
                        </RzRainbowButton>
                    </div>
                </RzBrowser>
                <RzCodeViewer Language="@CodeLanguage.Razor" class="mb-10">
&lt;RzRainbowButton Size="RainbowButtonSize.Icon" AriaLabel="Share"&gt;
    &lt;Blazicon Svg="@Lucide.Share2" aria-hidden="true" /&gt;
&lt;/RzRainbowButton&gt;
                </RzCodeViewer>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Parameters" class="scroll-mt-20">Parameters</RzHeading>
                <div class="not-prose mt-6 mb-10 overflow-hidden rounded-md border border-zinc-200 dark:border-zinc-800">
                    <table class="w-full text-sm">
                        <thead class="text-left bg-zinc-100/75 font-semibold text-zinc-700 dark:bg-zinc-900/50 dark:text-zinc-300">
                            <tr>
                                <th scope="col" class="w-1/5 px-4 py-3">Property</th>
                                <th scope="col" class="w-2/5 px-4 py-3">Description</th>
                                <th scope="col" class="w-1/5 px-4 py-3">Type</th>
                                <th scope="col" class="px-4 py-3">Default</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
                            <tr class="align-top"><td class="px-4 py-4"><code>ChildContent</code></td><td class="px-4 py-4">Inner content rendered by the button or child host.</td><td class="px-4 py-4"><code>RenderFragment?</code></td><td class="px-4 py-4"><code>null</code></td></tr>
                            <tr class="align-top"><td class="px-4 py-4"><code>AsChild</code></td><td class="px-4 py-4">Merges classes and attributes onto a provided child element.</td><td class="px-4 py-4"><code>bool</code></td><td class="px-4 py-4"><code>false</code></td></tr>
                            <tr class="align-top"><td class="px-4 py-4"><code>Variant</code></td><td class="px-4 py-4">Controls default or outline rainbow presentation.</td><td class="px-4 py-4"><code>RainbowButtonVariant</code></td><td class="px-4 py-4"><code>Default</code></td></tr>
                            <tr class="align-top"><td class="px-4 py-4"><code>Size</code></td><td class="px-4 py-4">Controls dimensions and spacing.</td><td class="px-4 py-4"><code>RainbowButtonSize</code></td><td class="px-4 py-4"><code>Default</code></td></tr>
                            <tr class="align-top"><td class="px-4 py-4"><code>AriaLabel</code></td><td class="px-4 py-4">Accessible name, especially important for icon-only buttons.</td><td class="px-4 py-4"><code>string?</code></td><td class="px-4 py-4"><code>null</code></td></tr>
                            <tr class="align-top"><td class="px-4 py-4"><code>Disabled</code></td><td class="px-4 py-4">Applies disabled semantics and visual treatment on native button host.</td><td class="px-4 py-4"><code>bool</code></td><td class="px-4 py-4"><code>false</code></td></tr>
                            <tr class="align-top"><td class="px-4 py-4"><code>Type</code></td><td class="px-4 py-4">Native button type for non-<code>AsChild</code> rendering.</td><td class="px-4 py-4"><code>string</code></td><td class="px-4 py-4"><code>"button"</code></td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Interoperability" class="scroll-mt-20">Interoperability</RzHeading>
                <RzParagraph>
                    Native HTML attributes and custom attributes are passed through via <code>AdditionalAttributes</code>, including <code>aria-*</code>, <code>data-*</code>, and <code>hx-*</code> attributes.
                </RzParagraph>
                <RzParagraph>
                    The component is fully SSR-safe and does not require Alpine initialization or any client bootstrap code.
                </RzParagraph>
            </section>
        </MainContent>
    </RzArticle>
</RzQuickReferenceContainer>
