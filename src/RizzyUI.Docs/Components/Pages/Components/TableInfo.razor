@page "/components/table"

<PageTitle>Table</PageTitle>

<RzQuickReferenceContainer>
    <RzArticle ProseWidth="ProseWidth.UltraWide">
        <SideContent>
            <RzQuickReference />
        </SideContent>
        <MainContent>
            <RzBreadcrumb class="mb-4 not-prose">
                <BreadcrumbList>
                    <BreadcrumbItem><BreadcrumbLink Href="/">Docs</BreadcrumbLink></BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem><BreadcrumbLink Href="/components">Components</BreadcrumbLink></BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem><BreadcrumbPage>Table</BreadcrumbPage></BreadcrumbItem>
                </BreadcrumbList>
            </RzBreadcrumb>

            <RzHeading Level="HeadingLevel.H1" QuickReferenceTitle="Table" class="scroll-mt-20">Table</RzHeading>
            <RzParagraph>
                <code>RzTable</code> is an SSR-first table composition suite aligned to shadcn/ui table structure.
                It renders table primitives on the server and emits browser <code>rz:</code> custom events for sort, paging, and selection interactions.
            </RzParagraph>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Example" class="scroll-mt-20">Example</RzHeading>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="p-4">
                        <TableDemo />
                    </div>
                </RzBrowser>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Browser Events" class="scroll-mt-20">Browser Events</RzHeading>
                <ul>
                    <li><code>rz:tableheadercell:on-sort-change</code></li>
                    <li><code>rz:tablepagination:on-page-change</code></li>
                    <li><code>rz:tablerow:on-selection-change</code></li>
                    <li><code>rz:table:on-state-change</code></li>
                </ul>
            </section>
        </MainContent>
    </RzArticle>
</RzQuickReferenceContainer>
