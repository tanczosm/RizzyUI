@page "/components/clipboard"
@using Blazicons
@using RizzyUI

<PageTitle>Clipboard</PageTitle>

<RzQuickReferenceContainer>
    <RzArticle ProseWidth="ProseWidth.UltraWide">
        <SideContent>
            <RzQuickReference />
        </SideContent>
        <MainContent>
            <RzBreadcrumb class="mb-4 not-prose">
                <BreadcrumbList>
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Docs</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/components" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Components</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BreadcrumbPage>Clipboard</BreadcrumbPage>
                    </BreadcrumbItem>
                </BreadcrumbList>
            </RzBreadcrumb>

            <RzHeading Level="HeadingLevel.H1" QuickReferenceTitle="Clipboard" class="scroll-mt-20">Clipboard</RzHeading>
            <RzParagraph>
                <b>RzClipboard</b> is an SSR-first primitive for one-click copy actions. Compose it with
                <code>ClipboardTrigger</code> and <code>ClipboardFeedback</code> to keep idle and copied states independent while preserving layout stability.
            </RzParagraph>

            <RzAlert Variant="ThemeVariant.Information" class="my-5">
                <AlertTitle>Under the Hood</AlertTitle>
                <AlertDescription>
                    Interactivity is powered by Alpine via <code>x-data="rzClipboard"</code>. The component first attempts
                    <code>navigator.clipboard.writeText</code> and can optionally fall back to <code>document.execCommand('copy')</code>
                    for broader compatibility in constrained environments.
                </AlertDescription>
            </RzAlert>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Example 1: Buttons" class="scroll-mt-20">Example 1: Buttons</RzHeading>
                <RzParagraph>Equivalent patterns for icon-only and text buttons.</RzParagraph>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto flex max-w-xl flex-col gap-3 p-8">
                        <div class="flex items-center gap-3">
                            <RzClipboard Value="Icon button clicked!" AriaLabel="Copy icon button text" AsChild>
                                <RzButton Variant=ThemeVariant.Secondary Outline Size=Size.Small class="px-2">
                                    <ClipboardTrigger>
                                        <span class="inline-flex"><Blazicon Svg="@MdiIcon.ContentCopy" aria-hidden="true" /></span>
                                        <span class="sr-only">Copy</span>
                                    </ClipboardTrigger>
                                    <ClipboardFeedback>
                                        <span class="inline-flex text-success"><Blazicon Svg="@MdiIcon.Check" aria-hidden="true" /></span>
                                        <span class="sr-only">Copied</span>
                                    </ClipboardFeedback>
                                </RzButton>
                            </RzClipboard>

                            <RzClipboard Value="Hello, World!" AsChild>
                                <RzButton Variant=ThemeVariant.Primary class="min-w-40">
                                    <ClipboardTrigger>
                                        <span class="inline-flex items-center gap-2"><Blazicon Svg="@MdiIcon.ContentCopy" aria-hidden="true" />Copy Content</span>
                                    </ClipboardTrigger>
                                    <ClipboardFeedback>
                                        <span class="inline-flex items-center gap-2"><Blazicon Svg="@MdiIcon.Check" aria-hidden="true" />Copied!</span>
                                    </ClipboardFeedback>
                                </RzButton>
                            </RzClipboard>
                        </div>
                    </div>
                </RzBrowser>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Example 2: Code Block" class="scroll-mt-20">Example 2: Code Block</RzHeading>
                <RzParagraph>Attach copy behavior to a compact command block action.</RzParagraph>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto max-w-xl p-8">
                        <div class="relative rounded-lg border border-zinc-200/75 bg-zinc-50 dark:border-zinc-700/75 dark:bg-zinc-800/75">
                            <div class="flex items-center justify-between">
                                <code class="grow p-4 text-sm text-zinc-700 dark:text-zinc-300">npm install alpinejs</code>
                                <RzClipboard Value="npm install alpinejs" AriaLabel="Copy npm command" AsChild>
                                    <RzButton Variant=ThemeVariant.Ghost Size=Size.Small class="mx-2 px-2">
                                        <ClipboardTrigger>
                                            <span class="inline-flex"><Blazicon Svg="@MdiIcon.ContentCopy" aria-hidden="true" /></span>
                                            <span class="sr-only">Copy code</span>
                                        </ClipboardTrigger>
                                        <ClipboardFeedback>
                                            <span class="inline-flex text-success"><Blazicon Svg="@MdiIcon.Check" aria-hidden="true" /></span>
                                            <span class="sr-only">Copied code</span>
                                        </ClipboardFeedback>
                                    </RzButton>
                                </RzClipboard>
                            </div>
                        </div>
                    </div>
                </RzBrowser>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Example 3: Input" class="scroll-mt-20">Example 3: Input</RzHeading>
                <RzParagraph>Use <code>TargetSelector</code> to copy from an input value.</RzParagraph>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto max-w-xl p-8">
                        <label for="website-url" class="mb-2 block text-sm font-semibold text-zinc-900 dark:text-zinc-100">Website URL</label>
                        <div class="relative">
                            <input id="website-url" type="text" value="https://pinemix.com/" readonly class="w-full rounded-lg border border-zinc-200/75 bg-white px-4 py-2.5 pe-20 text-sm leading-5 text-zinc-900 dark:border-zinc-700/75 dark:bg-transparent dark:text-zinc-100" />
                            <div class="absolute inset-y-0 end-0 flex items-center justify-center px-2">
                                <RzClipboard TargetSelector="#website-url" AriaLabel="Copy website URL" AsChild>
                                    <RzButton Variant=ThemeVariant.Secondary Outline Size=Size.Small>
                                        <ClipboardTrigger>Copy</ClipboardTrigger>
                                        <ClipboardFeedback><span class="text-success">Copied!</span></ClipboardFeedback>
                                    </RzButton>
                                </RzClipboard>
                            </div>
                        </div>
                    </div>
                </RzBrowser>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Example 4: API Key" class="scroll-mt-20">Example 4: API Key</RzHeading>
                <RzParagraph>Copy sensitive-looking tokens from compact list rows.</RzParagraph>
                <RzBrowser Layout="typeof(PreviewLayout)">
                    <div class="mx-auto max-w-xl p-8">
                        <div class="flex items-center justify-between gap-4 rounded-lg border border-zinc-200/75 p-4 dark:border-zinc-700/75">
                            <div class="min-w-0 flex-1">
                                <div class="text-sm font-medium text-zinc-900 dark:text-zinc-100">API Key</div>
                                <div class="mt-0.5 truncate font-mono text-xs text-zinc-600 dark:text-zinc-400">db_1234567890abcdefghijklmnopqrstuvwxyz</div>
                            </div>
                            <RzClipboard Value="db_1234567890abcdefghijklmnopqrstuvwxyz" AriaLabel="Copy API key" AsChild>
                                <RzButton Variant=ThemeVariant.Secondary Outline Size=Size.Small class="px-2">
                                    <ClipboardTrigger>
                                        <span class="inline-flex"><Blazicon Svg="@MdiIcon.ContentCopy" aria-hidden="true" /></span>
                                        <span class="sr-only">Copy API key</span>
                                    </ClipboardTrigger>
                                    <ClipboardFeedback>
                                        <span class="inline-flex text-success"><Blazicon Svg="@MdiIcon.Check" aria-hidden="true" /></span>
                                        <span class="sr-only">Copied API key</span>
                                    </ClipboardFeedback>
                                </RzButton>
                            </RzClipboard>
                        </div>
                    </div>
                </RzBrowser>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Component Parameters" class="scroll-mt-20">Component Parameters</RzHeading>
                <RzHeading Level="HeadingLevel.H3" class="mt-6">RzClipboard</RzHeading>
                <div class="not-prose mt-6 mb-10 overflow-hidden rounded-md border border-zinc-200 dark:border-zinc-800"><table class="w-full text-sm"><thead class="text-left bg-zinc-100/75 font-semibold text-zinc-700 dark:bg-zinc-900/50 dark:text-zinc-300"><tr><th scope="col" class="w-1/5 px-4 py-3">Property</th><th scope="col" class="w-2/5 px-4 py-3">Description</th><th scope="col" class="w-1/5 px-4 py-3">Type</th><th scope="col" class="px-4 py-3">Default</th></tr></thead><tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
                    <tr class="align-top"><td class="px-4 py-4"><code>ChildContent</code></td><td class="px-4 py-4">Clipboard composition content.</td><td class="px-4 py-4"><code>RenderFragment</code></td><td class="px-4 py-4">Required</td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>Value</code></td><td class="px-4 py-4">Direct text to copy.</td><td class="px-4 py-4"><code>string?</code></td><td class="px-4 py-4"><code>null</code></td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>TargetSelector</code></td><td class="px-4 py-4">Selector used to resolve source text.</td><td class="px-4 py-4"><code>string?</code></td><td class="px-4 py-4"><code>null</code></td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>PreferValue</code></td><td class="px-4 py-4">When true, <code>Value</code> is preferred when both are set.</td><td class="px-4 py-4"><code>bool</code></td><td class="px-4 py-4"><code>false</code></td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>FeedbackDuration</code></td><td class="px-4 py-4">Copied-state duration in milliseconds.</td><td class="px-4 py-4"><code>int</code></td><td class="px-4 py-4"><code>1200</code></td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>Disabled</code></td><td class="px-4 py-4">Disables all copy interaction.</td><td class="px-4 py-4"><code>bool</code></td><td class="px-4 py-4"><code>false</code></td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>UseFallback</code></td><td class="px-4 py-4">Allows execCommand fallback when Clipboard API is unavailable.</td><td class="px-4 py-4"><code>bool</code></td><td class="px-4 py-4"><code>true</code></td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>AriaLabel</code></td><td class="px-4 py-4">Accessible name for trigger host.</td><td class="px-4 py-4"><code>string?</code></td><td class="px-4 py-4"><code>"Copy to clipboard"</code></td></tr>
                </tbody></table></div>

                <RzHeading Level="HeadingLevel.H3" class="mt-6">ClipboardTrigger</RzHeading>
                <div class="not-prose mt-6 mb-10 overflow-hidden rounded-md border border-zinc-200 dark:border-zinc-800"><table class="w-full text-sm"><thead class="text-left bg-zinc-100/75 font-semibold text-zinc-700 dark:bg-zinc-900/50 dark:text-zinc-300"><tr><th scope="col" class="w-1/5 px-4 py-3">Property</th><th scope="col" class="w-2/5 px-4 py-3">Description</th><th scope="col" class="w-1/5 px-4 py-3">Type</th><th scope="col" class="px-4 py-3">Default</th></tr></thead><tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
                    <tr class="align-top"><td class="px-4 py-4"><code>ChildContent</code></td><td class="px-4 py-4">Content shown in idle state.</td><td class="px-4 py-4"><code>RenderFragment</code></td><td class="px-4 py-4">Required</td></tr>
                </tbody></table></div>

                <RzHeading Level="HeadingLevel.H3" class="mt-6">ClipboardFeedback</RzHeading>
                <div class="not-prose mt-6 mb-10 overflow-hidden rounded-md border border-zinc-200 dark:border-zinc-800"><table class="w-full text-sm"><thead class="text-left bg-zinc-100/75 font-semibold text-zinc-700 dark:bg-zinc-900/50 dark:text-zinc-300"><tr><th scope="col" class="w-1/5 px-4 py-3">Property</th><th scope="col" class="w-2/5 px-4 py-3">Description</th><th scope="col" class="w-1/5 px-4 py-3">Type</th><th scope="col" class="px-4 py-3">Default</th></tr></thead><tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
                    <tr class="align-top"><td class="px-4 py-4"><code>ChildContent</code></td><td class="px-4 py-4">Content shown in copied state.</td><td class="px-4 py-4"><code>RenderFragment</code></td><td class="px-4 py-4">Required</td></tr>
                </tbody></table></div>
            </section>

            <section class="my-8 py-2">
                <RzHeading Level="HeadingLevel.H2" QuickReferenceTitle="Alpine API / Events" class="scroll-mt-20">Alpine API / Events</RzHeading>
                <div class="not-prose mt-6 mb-10 overflow-hidden rounded-md border border-zinc-200 dark:border-zinc-800"><table class="w-full text-sm"><thead class="text-left bg-zinc-100/75 font-semibold text-zinc-700 dark:bg-zinc-900/50 dark:text-zinc-300"><tr><th scope="col" class="w-1/5 px-4 py-3">Event</th><th scope="col" class="w-1/5 px-4 py-3">Payload</th><th scope="col" class="px-4 py-3">Description</th></tr></thead><tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
                    <tr class="align-top"><td class="px-4 py-4"><code>rz:copy</code></td><td class="px-4 py-4"><code>{ id, text }</code></td><td class="px-4 py-4">Dispatched after successful copy.</td></tr>
                    <tr class="align-top"><td class="px-4 py-4"><code>rz:copy-failed</code></td><td class="px-4 py-4"><code>{ id, reason, error }</code></td><td class="px-4 py-4">Dispatched when copy fails (empty text, permissions, or unavailable clipboard).</td></tr>
                </tbody></table></div>

                <RzHeading Level="HeadingLevel.H3" class="mt-6">SSR/HTMX Notes</RzHeading>
                <RzParagraph>
                    Clipboard operations require user gesture and usually a secure context. In HTTP/non-secure contexts or strict browser policies,
                    enable <code>UseFallback</code> for <code>execCommand('copy')</code> compatibility. Events are plain DOM CustomEvents, so
                    HTMX listeners and vanilla JavaScript handlers can react without Blazor interactivity.
                </RzParagraph>

                <RzHeading Level="HeadingLevel.H3" class="mt-6">Accessibility & Theming Notes</RzHeading>
                <RzParagraph>
                    Provide a meaningful <code>AriaLabel</code> for icon-only triggers. <code>ClipboardFeedback</code> uses
                    <code>aria-live="polite"</code> for non-intrusive announcements. Style hooks are exposed via
                    <code>data-slot="clipboard"</code>, <code>data-slot="clipboard-trigger"</code>, and
                    <code>data-slot="clipboard-feedback"</code>, with styles resolved through the theme TvDescriptors.
                </RzParagraph>
            </section>
        </MainContent>
    </RzArticle>
</RzQuickReferenceContainer>
